    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0f0f1a;
            --bg-secondary: #1a1a2e;
            --bg-card: #252540;
            --bg-card-hover: #2f2f50;
            --text-primary: #f0eef8;
            --text-secondary: #b8b0d0;
            --accent-gold: #f5c842;
            --accent-green: #58cc71;
            --accent-red: #ff6b6b;
            --accent-blue: #6bc5f7;
            --accent-purple: #a78bfa;
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
            --radius: 20px;
            --radius-sm: 12px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            padding: 0 0 40px 0;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-gold);
            border-radius: 10px;
        }

        /* ===== HEADER ===== */
        .app-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 24px;
            background: var(--bg-secondary);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            position: sticky;
            top: 0;
            z-index: 50;
            backdrop-filter: blur(12px);
        }

        .app-header .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .app-header .brand .flag {
            font-size: 28px;
            line-height: 1;
        }

        .app-header .brand h1 {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent-gold), #f0a030);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 0.5px;
        }

        .app-header .brand h1 span {
            font-weight: 300;
            -webkit-text-fill-color: var(--text-secondary);
            font-size: 16px;
        }

        .header-hearts {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 22px;
            color: var(--accent-red);
            background: rgba(255, 107, 107, 0.12);
            padding: 6px 16px 6px 12px;
            border-radius: 30px;
            border: 1px solid rgba(255, 107, 107, 0.2);
        }

        .header-hearts .heart-count {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            min-width: 20px;
            text-align: center;
        }

        /* ===== STAGE PROGRESS BAR ===== */
        .stage-progress {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px 20px;
            background: var(--bg-secondary);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            flex-wrap: wrap;
        }

        .stage-progress .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--bg-card);
            border: 2px solid #3a3a5a;
            transition: var(--transition);
        }
        .stage-progress .dot.active {
            background: var(--accent-gold);
            border-color: var(--accent-gold);
            box-shadow: 0 0 16px rgba(245, 200, 66, 0.4);
        }
        .stage-progress .dot.done {
            background: var(--accent-green);
            border-color: var(--accent-green);
        }
        .stage-progress .line {
            width: 30px;
            height: 2px;
            background: #3a3a5a;
            border-radius: 2px;
            transition: var(--transition);
        }
        .stage-progress .line.done {
            background: var(--accent-green);
        }

        /* ===== MAIN CONTAINER ===== */
        .app-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px 16px 40px;
        }

        /* ===== PATH ===== */
        .path-container {
            position: relative;
            padding: 20px 0 10px;
        }

        .path-line {
            position: absolute;
            left: 50%;
            top: 40px;
            bottom: 40px;
            width: 4px;
            background: linear-gradient(to bottom,
                    rgba(245, 200, 66, 0.3),
                    rgba(245, 200, 66, 0.1) 30%,
                    rgba(245, 200, 66, 0.05) 60%,
                    rgba(245, 200, 66, 0.02));
            transform: translateX(-50%);
            border-radius: 4px;
            z-index: 0;
        }

        .path-line .fill {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 0%;
            background: linear-gradient(to bottom, var(--accent-gold), #f0a030);
            border-radius: 4px;
            transition: height 0.8s ease;
        }

        /* ===== STAGE CARD ===== */
        .stage-item {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
            padding: 16px 20px;
            background: var(--bg-secondary);
            border-radius: var(--radius);
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: var(--shadow);
            transition: var(--transition);
            cursor: pointer;
            opacity: 0.5;
            pointer-events: none;
            transform: scale(0.97);
        }

        .stage-item.active {
            opacity: 1;
            pointer-events: auto;
            transform: scale(1);
            border-color: rgba(245, 200, 66, 0.3);
            box-shadow: 0 8px 40px rgba(245, 200, 66, 0.08);
        }

        .stage-item.completed {
            opacity: 0.7;
            pointer-events: auto;
            transform: scale(0.98);
            border-color: rgba(88, 204, 113, 0.2);
        }

        .stage-item.completed .stage-icon {
            filter: grayscale(0);
        }

        .stage-item .stage-icon {
            font-size: 40px;
            width: 64px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-card);
            border-radius: 50%;
            flex-shrink: 0;
            border: 2px solid rgba(255, 255, 255, 0.06);
            transition: var(--transition);
        }

        .stage-item.active .stage-icon {
            border-color: var(--accent-gold);
            box-shadow: 0 0 30px rgba(245, 200, 66, 0.15);
        }

        .stage-item .stage-info {
            flex: 1;
        }

        .stage-item .stage-info h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text-primary);
        }

        .stage-item .stage-info p {
            font-size: 14px;
            color: var(--text-secondary);
        }

        .stage-item .stage-status {
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
        }

        .stage-item.active .stage-status {
            color: var(--accent-gold);
        }

        .stage-item.completed .stage-status {
            color: var(--accent-green);
        }

        .stage-item .treasure {
            font-size: 22px;
            margin-right: 4px;
        }

        /* ===== LESSON VIEW ===== */
        .lesson-view {
            display: none;
            animation: fadeSlideUp 0.4s ease;
        }

        .lesson-view.visible {
            display: block;
        }

        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .lesson-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .lesson-header .back-btn {
            background: var(--bg-card);
            border: none;
            color: var(--text-secondary);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            font-size: 18px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lesson-header .back-btn:hover {
            background: var(--bg-card-hover);
            color: var(--text-primary);
        }

        .lesson-header h2 {
            font-size: 20px;
            font-weight: 600;
        }

        .lesson-header .lesson-icon {
            font-size: 28px;
            margin-left: auto;
        }

        /* ===== CARDS ===== */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 16px;
            margin-bottom: 28px;
        }

        .word-card {
            background: var(--bg-card);
            border-radius: var(--radius-sm);
            padding: 20px 16px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            border: 1px solid rgba(255, 255, 255, 0.04);
            perspective: 800px;
            min-height: 180px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .word-card:hover {
            background: var(--bg-card-hover);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
        }

        .word-card .card-inner {
            width: 100%;
            transition: transform 0.5s ease;
            transform-style: preserve-3d;
        }

        .word-card.flipped .card-inner {
            transform: rotateY(180deg);
        }

        .word-card .card-front,
        .word-card .card-back {
            backface-visibility: hidden;
            width: 100%;
        }

        .word-card .card-back {
            position: absolute;
            top: 0;
            left: 0;
            transform: rotateY(180deg);
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
        }

        .word-card .card-front .hiragana {
            font-size: 32px;
            font-weight: 700;
            margin: 8px 0 4px;
            color: var(--text-primary);
        }

        .word-card .card-front .emoji-big {
            font-size: 44px;
            margin-bottom: 6px;
        }

        .word-card .card-front .pronounce-hint {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .word-card .card-back .translations {
            font-size: 14px;
            line-height: 1.8;
        }

        .word-card .card-back .translations strong {
            color: var(--accent-gold);
        }

        .word-card .card-back .translations .ar {
            color: #6bc5f7;
        }
        .word-card .card-back .translations .en {
            color: #58cc71;
        }
        .word-card .card-back .translations .rom {
            color: #f5c842;
        }

        .word-card .audio-btn {
            position: absolute;
            bottom: 10px;
            right: 12px;
            background: rgba(255, 255, 255, 0.06);
            border: none;
            color: var(--text-secondary);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            font-size: 14px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .word-card .audio-btn:hover {
            background: rgba(245, 200, 66, 0.2);
            color: var(--accent-gold);
        }

        .flip-hint {
            font-size: 11px;
            color: var(--text-secondary);
            margin-top: 10px;
            opacity: 0.6;
        }

        /* ===== QUIZ ===== */
        .quiz-section {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .quiz-section h3 {
            font-size: 18px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quiz-question {
            background: var(--bg-card);
            border-radius: var(--radius-sm);
            padding: 20px;
            margin-bottom: 16px;
        }

        .quiz-question .q-text {
            font-size: 18px;
            font-weight: 500;
            margin-bottom: 14px;
        }

        .quiz-question .q-text .highlight {
            color: var(--accent-gold);
            font-size: 24px;
        }

        .quiz-options {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .quiz-options button {
            background: var(--bg-primary);
            border: 2px solid rgba(255, 255, 255, 0.06);
            color: var(--text-primary);
            padding: 14px 18px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            text-align: left;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .quiz-options button:hover:not(:disabled) {
            background: var(--bg-card-hover);
            border-color: rgba(245, 200, 66, 0.2);
        }

        .quiz-options button.correct {
            border-color: var(--accent-green);
            background: rgba(88, 204, 113, 0.15);
        }

        .quiz-options button.wrong {
            border-color: var(--accent-red);
            background: rgba(255, 107, 107, 0.15);
        }

        .quiz-options button:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .quiz-options button .opt-label {
            font-weight: 700;
            color: var(--text-secondary);
            min-width: 28px;
        }

        /* ===== WRITING ===== */
        .writing-section {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .writing-section h3 {
            font-size: 18px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .writing-box {
            background: var(--bg-card);
            border-radius: var(--radius-sm);
            padding: 20px;
        }

        .writing-box .prompt {
            font-size: 16px;
            margin-bottom: 12px;
            color: var(--text-secondary);
        }

        .writing-box .prompt .target {
            color: var(--accent-gold);
            font-weight: 600;
            font-size: 20px;
        }

        .writing-box input {
            width: 100%;
            padding: 14px 18px;
            background: var(--bg-primary);
            border: 2px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            font-size: 22px;
            font-weight: 500;
            outline: none;
            transition: var(--transition);
            letter-spacing: 2px;
        }

        .writing-box input:focus {
            border-color: var(--accent-gold);
            box-shadow: 0 0 20px rgba(245, 200, 66, 0.05);
        }

        .writing-box input::placeholder {
            color: var(--text-secondary);
            font-size: 16px;
            font-weight: 400;
            letter-spacing: 0;
        }

        .writing-box .writing-actions {
            display: flex;
            gap: 12px;
            margin-top: 14px;
            flex-wrap: wrap;
        }

        .writing-box .writing-actions button {
            padding: 10px 28px;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            flex: 1;
            min-width: 100px;
        }

        .btn-check {
            background: var(--accent-gold);
            color: #0f0f1a;
        }

        .btn-check:hover:not(:disabled) {
            background: #e6b832;
            transform: scale(1.02);
        }

        .btn-check:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .btn-skip {
            background: var(--bg-card);
            color: var(--text-secondary);
        }

        .btn-skip:hover {
            background: var(--bg-card-hover);
            color: var(--text-primary);
        }

        .writing-feedback {
            margin-top: 12px;
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            font-weight: 500;
            display: none;
        }

        .writing-feedback.show {
            display: block;
        }

        .writing-feedback.correct {
            background: rgba(88, 204, 113, 0.12);
            color: var(--accent-green);
            border: 1px solid rgba(88, 204, 113, 0.2);
        }

        .writing-feedback.wrong {
            background: rgba(255, 107, 107, 0.12);
            color: var(--accent-red);
            border: 1px solid rgba(255, 107, 107, 0.2);
        }

        /* ===== STAGE COMPLETE ===== */
        .stage-complete {
            text-align: center;
            padding: 40px 20px;
            background: var(--bg-secondary);
            border-radius: var(--radius);
            border: 1px solid rgba(88, 204, 113, 0.15);
            animation: fadeSlideUp 0.5s ease;
        }

        .stage-complete .big-icon {
            font-size: 72px;
            margin-bottom: 16px;
        }

        .stage-complete h2 {
            font-size: 28px;
            color: var(--accent-green);
            margin-bottom: 8px;
        }

        .stage-complete p {
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .stage-complete .btn-next {
            background: var(--accent-gold);
            color: #0f0f1a;
            border: none;
            padding: 14px 40px;
            border-radius: var(--radius-sm);
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

        .stage-complete .btn-next:hover {
            transform: scale(1.04);
            box-shadow: 0 8px 30px rgba(245, 200, 66, 0.2);
        }

        /* ===== GAME OVER OVERLAY ===== */
        .game-over-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
            padding: 24px;
        }

        .game-over-overlay.visible {
            display: flex;
        }

        .game-over-box {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            padding: 40px 32px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            border: 1px solid rgba(255, 107, 107, 0.2);
            animation: fadeSlideUp 0.4s ease;
        }

        .game-over-box .big-icon {
            font-size: 64px;
            margin-bottom: 12px;
        }

        .game-over-box h2 {
            font-size: 26px;
            color: var(--accent-red);
            margin-bottom: 6px;
        }

        .game-over-box p {
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .game-over-box .btn-restart {
            background: var(--accent-gold);
            color: #0f0f1a;
            border: none;
            padding: 14px 36px;
            border-radius: var(--radius-sm);
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

        .game-over-box .btn-restart:hover {
            transform: scale(1.04);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 480px) {
            .app-header {
                padding: 12px 16px;
            }
            .app-header .brand h1 {
                font-size: 18px;
            }
            .app-header .brand h1 span {
                font-size: 13px;
            }
            .header-hearts {
                font-size: 18px;
                padding: 4px 12px 4px 8px;
            }
            .header-hearts .heart-count {
                font-size: 16px;
            }
            .stage-item {
                padding: 12px 16px;
                gap: 14px;
                margin-bottom: 28px;
            }
            .stage-item .stage-icon {
                width: 50px;
                height: 50px;
                font-size: 30px;
            }
            .stage-item .stage-info h3 {
                font-size: 16px;
            }
            .cards-grid {
                grid-template-columns: 1fr 1fr;
            }
            .word-card {
                min-height: 150px;
                padding: 16px 12px;
            }
            .word-card .card-front .hiragana {
                font-size: 26px;
            }
            .word-card .card-front .emoji-big {
                font-size: 34px;
            }
            .quiz-options button {
                padding: 12px 14px;
                font-size: 14px;
            }
            .writing-box input {
                font-size: 18px;
                padding: 12px 14px;
            }
            .lesson-header h2 {
                font-size: 17px;
            }
            .stage-progress .line {
                width: 18px;
            }
        }

        @media (max-width: 380px) {
            .cards-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ===== UTILITY ===== */
        .hidden {
            display: none !important;
        }

        .mt-8 {
            margin-top: 8px;
        }
        .mb-8 {
            margin-bottom: 8px;
        }
        .text-center {
            text-align: center;
        }

        /* ===== TYPING CURSOR GLOW ===== */
        .writing-box input:focus::placeholder {
            opacity: 0.3;
        }

        /* ===== HEART BEAT ANIMATION ===== */
        @keyframes heartBeat {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.15);
            }
        }
        .heart-beat {
            animation: heartBeat 0.3s ease;
        }
    </style>
</head>
<body>

    <!-- ===== HEADER ===== -->
    <header class="app-header">
        <div class="brand">
            <span class="flag">🇩🇿</span>
            <h1>Mehdi <span>San</span></h1>
        </div>
        <div class="header-hearts" id="headerHearts">
            <i class="fas fa-heart"></i>
            <span class="heart-count" id="heartCount">6</span>
        </div>
    </header>

    <!-- ===== STAGE PROGRESS DOTS ===== -->
    <div class="stage-progress" id="stageProgress"></div>

    <!-- ===== MAIN ===== -->
    <div class="app-container">

        <!-- ===== PATH VIEW ===== -->
        <div id="pathView">
            <div class="path-container">
                <div class="path-line">
                    <div class="fill" id="pathFill" style="height:0%;"></div>
                </div>
                <div id="stageList"></div>
            </div>
        </div>

        <!-- ===== LESSON VIEW ===== -->
        <div class="lesson-view" id="lessonView">
            <div class="lesson-header">
                <button class="back-btn" id="backToPath"><i class="fas fa-arrow-left"></i></button>
                <h2 id="lessonTitle">Lesson</h2>
                <span class="lesson-icon" id="lessonIcon">🌸</span>
            </div>
            <div id="lessonContent"></div>
        </div>

    </div>

    <!-- ===== GAME OVER OVERLAY ===== -->
    <div class="game-over-overlay" id="gameOverOverlay">
        <div class="game-over-box">
            <div class="big-icon">💔</div>
            <h2>Stage Lost!</h2>
            <p>You ran out of hearts. Don't give up — try again!</p>
            <button class="btn-restart" id="restartStageBtn">🔄 Try Again</button>
        </div>
    </div>

    <script>
        // ================================================================
        //  DATA
        // ================================================================

        const STAGES = [{
            id: 0,
            name: 'Basic Hiragana',
            icon: '🌸',
            treasure: '📦',
            desc: 'Learn あ, い, う, え, お',
            cards: [
                { hira: 'あ', emoji: '👋', romaji: 'a', ar: 'أ', en: 'Ah' },
                { hira: 'い', emoji: '😊', romaji: 'i', ar: 'إ', en: 'Ee' },
                { hira: 'う', emoji: '🐟', romaji: 'u', ar: 'أو', en: 'Oo' },
                { hira: 'え', emoji: '✏️', romaji: 'e', ar: 'إي', en: 'Eh' },
                { hira: 'お', emoji: '🙏', romaji: 'o', ar: 'أو', en: 'Oh' },
            ],
            quiz: [
                { q: 'What is the Hiragana for "a"?', options: ['あ', 'い', 'う'], correct: 0 },
                { q: 'What is the Hiragana for "i"?', options: ['え', 'い', 'お'], correct: 1 },
                { q: 'What is the Hiragana for "u"?', options: ['う', 'あ', 'え'], correct: 0 },
            ],
            writing: [
                { prompt: 'Type the Hiragana for "a"', answer: 'あ' },
                { prompt: 'Type the Hiragana for "i"', answer: 'い' },
                { prompt: 'Type the Hiragana for "u"', answer: 'う' },
            ]
        }, {
            id: 1,
            name: 'Pronunciation',
            icon: '⛩️',
            treasure: '📦',
            desc: 'Master か, き, く, け, こ',
            cards: [
                { hira: 'か', emoji: '🦋', romaji: 'ka', ar: 'كا', en: 'Ka' },
                { hira: 'き', emoji: '🌳', romaji: 'ki', ar: 'كي', en: 'Ki' },
                { hira: 'く', emoji: '🐻', romaji: 'ku', ar: 'كو', en: 'Ku' },
                { hira: 'け', emoji: '⚔️', romaji: 'ke', ar: 'كي', en: 'Ke' },
                { hira: 'こ', emoji: '🌀', romaji: 'ko', ar: 'كو', en: 'Ko' },
            ],
            quiz: [
                { q: 'What is the pronunciation of か?', options: ['ka', 'ki', 'ku'], correct: 0 },
                { q: 'What is the pronunciation of き?', options: ['ke', 'ki', 'ko'], correct: 1 },
                { q: 'What is the pronunciation of く?', options: ['ku', 'ka', 'ke'], correct: 0 },
            ],
            writing: [
                { prompt: 'Type the Hiragana for "ka"', answer: 'か' },
                { prompt: 'Type the Hiragana for "ki"', answer: 'き' },
                { prompt: 'Type the Hiragana for "ku"', answer: 'く' },
            ]
        }, {
            id: 2,
            name: 'Compound Sounds',
            icon: '🏠',
            treasure: '📦',
            desc: 'きゃ, きゅ, きょ, しゃ, しゅ, しょ',
            cards: [
                { hira: 'きゃ', emoji: '🎯', romaji: 'kya', ar: 'كيا', en: 'Kya' },
                { hira: 'きゅ', emoji: '🍡', romaji: 'kyu', ar: 'كيو', en: 'Kyu' },
                { hira: 'きょ', emoji: '🚀', romaji: 'kyo', ar: 'كيو', en: 'Kyo' },
                { hira: 'しゃ', emoji: '🌸', romaji: 'sha', ar: 'شا', en: 'Sha' },
                { hira: 'しゅ', emoji: '🎀', romaji: 'shu', ar: 'شو', en: 'Shu' },
                { hira: 'しょ', emoji: '🌊', romaji: 'sho', ar: 'شو', en: 'Sho' },
            ],
            quiz: [
                { q: 'What is きゃ?', options: ['kya', 'kyu', 'kyo'], correct: 0 },
                { q: 'What is しゃ?', options: ['sha', 'shu', 'sho'], correct: 0 },
                { q: 'What is きょ?', options: ['kyo', 'kya', 'kyu'], correct: 0 },
            ],
            writing: [
                { prompt: 'Type the Hiragana for "kya"', answer: 'きゃ' },
                { prompt: 'Type the Hiragana for "sha"', answer: 'しゃ' },
                { prompt: 'Type the Hiragana for "kyo"', answer: 'きょ' },
            ]
        }, {
            id: 3,
            name: 'Final Mastery',
            icon: '🗻',
            treasure: '🏆',
            desc: 'Review all Hiragana!',
            cards: [
                { hira: 'あ', emoji: '👋', romaji: 'a', ar: 'أ', en: 'Ah' },
                { hira: 'か', emoji: '🦋', romaji: 'ka', ar: 'كا', en: 'Ka' },
                { hira: 'きゃ', emoji: '🎯', romaji: 'kya', ar: 'كيا', en: 'Kya' },
                { hira: 'しゃ', emoji: '🌸', romaji: 'sha', ar: 'شا', en: 'Sha' },
                { hira: 'こ', emoji: '🌀', romaji: 'ko', ar: 'كو', en: 'Ko' },
            ],
            quiz: [
                { q: 'What is あ?', options: ['a', 'i', 'u'], correct: 0 },
                { q: 'What is か?', options: ['ka', 'ki', 'ku'], correct: 0 },
                { q: 'What is きゃ?', options: ['kya', 'kyu', 'kyo'], correct: 0 },
            ],
            writing: [
                { prompt: 'Type the Hiragana for "a"', answer: 'あ' },
                { prompt: 'Type the Hiragana for "ka"', answer: 'か' },
                { prompt: 'Type the Hiragana for "kya"', answer: 'きゃ' },
            ]
        }];

        // ================================================================
        //  STATE
        // ================================================================

        let state = {
            currentStage: 0, // which stage index
            hearts: 6,
            maxHearts: 6,
            stageCompleted: false, // for current stage
            allCompleted: false,
            // per-stage progress
            stageProgress: STAGES.map(() => ({
                cardsFlipped: false,
                quizAnswered: false,
                writingAnswered: false,
                // track which quiz/writing items have been done
                quizDone: [],
                writingDone: [],
                completed: false,
            })),
            // which stages are fully done (for path)
            stagesDone: STAGES.map(() => false),
            // current lesson sub-state
            quizIndex: 0,
            writingIndex: 0,
            quizLocked: false,
            writingLocked: false,
        };

        // ================================================================
        //  DOM REFS
        // ================================================================

        const $ = id => document.getElementById(id);
        const stageList = $('stageList');
        const pathFill = $('pathFill');
        const stageProgress = $('stageProgress');
        const pathView = $('pathView');
        const lessonView = $('lessonView');
        const lessonTitle = $('lessonTitle');
        const lessonIcon = $('lessonIcon');
        const lessonContent = $('lessonContent');
        const backBtn = $('backToPath');
        const heartCount = $('heartCount');
        const headerHearts = $('headerHearts');
        const gameOverOverlay = $('gameOverOverlay');
        const restartBtn = $('restartStageBtn');

        // ================================================================
        //  AUDIO (Web Speech)
        // ================================================================

        function speak(text, lang = 'ja-JP') {
            if (!window.speechSynthesis) return;
            window.speechSynthesis.cancel();
            const utter = new SpeechSynthesisUtterance(text);
            utter.lang = lang;
            utter.rate = 0.9;
            utter.pitch = 1.0;
            window.speechSynthesis.speak(utter);
        }

        // ================================================================
        //  RENDER: PATH
        // ================================================================

        function renderPath() {
            // progress dots
            const dotsHtml = STAGES.map((s, i) => {
                let cls = 'dot';
                if (state.stagesDone[i]) cls += ' done';
                else if (i === state.currentStage) cls += ' active';
                return `<span class="${cls}"></span>`;
            }).join('');
            const linesHtml = STAGES.slice(0, -1).map((_, i) => {
                const done = state.stagesDone[i] ? 'done' : '';
                return `<span class="line ${done}"></span>`;
            }).join('');
            stageProgress.innerHTML = dotsHtml + linesHtml;

            // path fill
            const doneCount = state.stagesDone.filter(Boolean).length;
            const total = STAGES.length;
            const pct = doneCount / total * 100;
            pathFill.style.height = Math.min(pct, 100) + '%';

            // stage list
            let html = '';
            STAGES.forEach((s, i) => {
                const isActive = i === state.currentStage && !state.stagesDone[i];
                const isCompleted = state.stagesDone[i];
                const cls = isCompleted ? 'completed' : (isActive ? 'active' : '');
                const statusIcon = isCompleted ? '✅' : (isActive ? '👉' : '🔒');
                const treasureIcon = s.treasure || '📦';

                html += `
                    <div class="stage-item ${cls}" data-index="${i}">
                        <div class="stage-icon">${s.icon}</div>
                        <div class="stage-info">
                            <h3>${s.name} <span class="treasure">${treasureIcon}</span></h3>
                            <p>${s.desc}</p>
                        </div>
                        <div class="stage-status">${statusIcon}</div>
                    </div>
                `;
            });
            stageList.innerHTML = html;

            // click handlers
            document.querySelectorAll('.stage-item').forEach(el => {
                el.addEventListener('click', () => {
                    const idx = parseInt(el.dataset.index);
                    if (state.stagesDone[idx]) {
                        // can re-enter completed stage? we allow it
                        openStage(idx);
                    } else if (idx === state.currentStage) {
                        openStage(idx);
                    }
                    // else locked
                });
            });
        }

        // ================================================================
        //  RENDER: LESSON
        // ================================================================

        function openStage(index) {
            const stage = STAGES[index];
            state.currentStage = index;
            state.stageCompleted = state.stagesDone[index];
            // reset sub-indexes if not completed
            if (!state.stagesDone[index]) {
                state.quizIndex = 0;
                state.writingIndex = 0;
                state.quizLocked = false;
                state.writingLocked = false;
                // reset per-stage progress flags
                const prog = state.stageProgress[index];
                prog.quizDone = [];
                prog.writingDone = [];
                prog.cardsFlipped = false;
                prog.quizAnswered = false;
                prog.writingAnswered = false;
            }

            pathView.style.display = 'none';
            lessonView.classList.add('visible');
            lessonTitle.textContent = stage.name;
            lessonIcon.textContent = stage.icon;

            renderLesson(index);
            updateHearts();
        }

        function renderLesson(index) {
            const stage = STAGES[index];
            const prog = state.stageProgress[index];
            const completed = state.stagesDone[index];

            let html = '';

            // ---- CARDS ----
            html += `<div class="cards-grid">`;
            stage.cards.forEach((card, ci) => {
                const flipped = prog.cardsFlipped ? 'flipped' : '';
                html += `
                    <div class="word-card ${flipped}" data-card="${ci}" data-hira="${card.hira}">
                        <div class="card-inner">
                            <div class="card-front">
                                <div class="emoji-big">${card.emoji}</div>
                                <div class="hiragana">${card.hira}</div>
                                <div class="pronounce-hint">🔊 tap to hear</div>
                            </div>
                            <div class="card-back">
                                <div class="translations">
                                    <div><span class="ar">🇸🇦 ${card.ar}</span></div>
                                    <div><span class="en">🇬🇧 ${card.en}</span></div>
                                    <div><span class="rom">🇯🇵 ${card.romaji}</span></div>
                                </div>
                            </div>
                        </div>
                        <button class="audio-btn" data-hira="${card.hira}" title="Listen">
                            <i class="fas fa-volume-up"></i>
                        </button>
                        <div class="flip-hint">👆 tap to flip</div>
                    </div>
                `;
            });
            html += `</div>`;

            // ---- QUIZ ----
            if (!completed) {
                html += `<div class="quiz-section">`;
                html += `<h3>📝 Multiple Choice</h3>`;
                const qIndex = state.quizIndex;
                if (qIndex < stage.quiz.length) {
                    const q = stage.quiz[qIndex];
                    const done = prog.quizDone.includes(qIndex);
                    html += `<div class="quiz-question">`;
                    html += `<div class="q-text">${q.q}</div>`;
                    html += `<div class="quiz-options" data-qindex="${qIndex}">`;
                    const labels = ['A', 'B', 'C'];
                    q.options.forEach((opt, oi) => {
                        const disabled = done ? 'disabled' : '';
                        const cls = done ? (oi === q.correct ? 'correct' : '') : '';
                        html += `
                            <button class="${cls}" data-opt="${oi}" ${disabled}>
                                <span class="opt-label">${labels[oi]}</span>
                                ${opt}
                            </button>
                        `;
                    });
                    html += `</div>`;
                    if (done) {
                        html += `<p style="color:var(--accent-green);margin-top:10px;">✅ Correct!</p>`;
                    }
                    html += `</div>`;
                } else {
                    html += `<p style="color:var(--accent-green);">✅ All quiz questions completed!</p>`;
                }
                html += `</div>`;

                // ---- WRITING ----
                html += `<div class="writing-section">`;
                html += `<h3>✍️ Writing Practice</h3>`;
                const wIndex = state.writingIndex;
                if (wIndex < stage.writing.length) {
                    const w = stage.writing[wIndex];
                    const done = prog.writingDone.includes(wIndex);
                    html += `
                        <div class="writing-box" data-windex="${wIndex}">
                            <div class="prompt">Write the Hiragana for: <span class="target">${w.prompt}</span></div>
                            <input type="text" placeholder="Type Hiragana..." id="writingInput" ${done ? 'disabled' : ''} />
                            <div class="writing-actions">
                                <button class="btn-check" id="checkWriting" ${done ? 'disabled' : ''}>✅ Check</button>
                                <button class="btn-skip" id="skipWriting" ${done ? 'disabled' : ''}>⏭️ Skip</button>
                            </div>
                            <div class="writing-feedback" id="writingFeedback"></div>
                            ${done ? `<p style="color:var(--accent-green);margin-top:10px;">✅ Completed!</p>` : ''}
                        </div>
                    `;
                } else {
                    html += `<p style="color:var(--accent-green);">✅ All writing exercises completed!</p>`;
                }
                html += `</div>`;
            }

            // ---- COMPLETED STAGE ----
            if (completed) {
                html += `
                    <div class="stage-complete">
                        <div class="big-icon">🎉</div>
                        <h2>Stage Complete!</h2>
                        <p>You've mastered ${stage.name}. Keep going!</p>
                        <button class="btn-next" id="nextStageBtn">➡️ Next Stage</button>
                    </div>
                `;
            }

            lessonContent.innerHTML = html;
            bindLessonEvents(index);
        }

        // ================================================================
        //  BIND LESSON EVENTS
        // ================================================================

        function bindLessonEvents(index) {
            const stage = STAGES[index];
            const prog = state.stageProgress[index];
            const completed = state.stagesDone[index];

            // ---- CARDS: flip & audio ----
            document.querySelectorAll('.word-card').forEach(card => {
                // flip
                card.addEventListener('click', (e) => {
                    if (e.target.closest('.audio-btn')) return;
                    card.classList.toggle('flipped');
                    prog.cardsFlipped = true;
                });

                // audio
                const audioBtn = card.querySelector('.audio-btn');
                if (audioBtn) {
                    audioBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const hira = audioBtn.dataset.hira;
                        speak(hira, 'ja-JP');
                        // also speak romaji if available
                        const cardData = stage.cards.find(c => c.hira === hira);
                        if (cardData) {
                            setTimeout(() => speak(cardData.romaji, 'ja-JP'), 400);
                        }
                    });
                }
            });

            // ---- QUIZ ----
            const qIndex = state.quizIndex;
            if (qIndex < stage.quiz.length && !prog.quizDone.includes(qIndex)) {
                const optionsContainer = document.querySelector('.quiz-options');
                if (optionsContainer) {
                    const buttons = optionsContainer.querySelectorAll('button');
                    buttons.forEach(btn => {
                        btn.addEventListener('click', function() {
                            if (state.quizLocked) return;
                            const opt = parseInt(this.dataset.opt);
                            const q = stage.quiz[qIndex];
                            const correct = opt === q.correct;
                            if (correct) {
                                this.classList.add('correct');
                                prog.quizDone.push(qIndex);
                                state.quizIndex++;
                                // check if all quiz done
                                if (state.quizIndex >= stage.quiz.length) {
                                    prog.quizAnswered = true;
                                }
                                // disable all
                                buttons.forEach(b => b.disabled = true);
                                // re-render after short delay
                                setTimeout(() => renderLesson(index), 600);
                            } else {
                                this.classList.add('wrong');
                                loseHeart(index);
                                // re-enable after a moment? No, we want to let them try again
                                setTimeout(() => {
                                    this.classList.remove('wrong');
                                }, 500);
                            }
                        });
                    });
                }
            }

            // ---- WRITING ----
            const wIndex = state.writingIndex;
            if (wIndex < stage.writing.length && !prog.writingDone.includes(wIndex)) {
                const input = document.getElementById('writingInput');
                const checkBtn = document.getElementById('checkWriting');
                const skipBtn = document.getElementById('skipWriting');
                const feedback = document.getElementById('writingFeedback');

                if (checkBtn && input) {
                    checkBtn.addEventListener('click', () => {
                        if (state.writingLocked) return;
                        const val = input.value.trim();
                        const w = stage.writing[wIndex];
                        if (val === w.answer) {
                            feedback.className = 'writing-feedback show correct';
                            feedback.textContent = '✅ Perfect!';
                            prog.writingDone.push(wIndex);
                            state.writingIndex++;
                            if (state.writingIndex >= stage.writing.length) {
                                prog.writingAnswered = true;
                            }
                            checkBtn.disabled = true;
                            skipBtn.disabled = true;
                            input.disabled = true;
                            state.writingLocked = true;
                            setTimeout(() => renderLesson(index), 700);
                        } else {
                            feedback.className = 'writing-feedback show wrong';
                            feedback.textContent = `❌ Incorrect. Try again! (Hint: ${w.answer})`;
                            loseHeart(index);
                            // clear after a moment
                            setTimeout(() => {
                                feedback.className = 'writing-feedback';
                            }, 800);
                        }
                    });
                }

                if (skipBtn) {
                    skipBtn.addEventListener('click', () => {
                        if (state.writingLocked) return;
                        // skip: show answer and move on
                        const w = stage.writing[wIndex];
                        feedback.className = 'writing-feedback show correct';
                        feedback.textContent = `⏭️ Skipped. Answer: ${w.answer}`;
                        prog.writingDone.push(wIndex);
                        state.writingIndex++;
                        if (state.writingIndex >= stage.writing.length) {
                            prog.writingAnswered = true;
                        }
                        checkBtn.disabled = true;
                        skipBtn.disabled = true;
                        input.disabled = true;
                        state.writingLocked = true;
                        setTimeout(() => renderLesson(index), 800);
                    });
                }
            }

            // ---- NEXT STAGE (if completed) ----
            const nextBtn = document.getElementById('nextStageBtn');
            if (nextBtn) {
                nextBtn.addEventListener('click', () => {
                    const nextIdx = index + 1;
                    if (nextIdx < STAGES.length) {
                        state.currentStage = nextIdx;
                        // mark previous as done
                        state.stagesDone[index] = true;
                        renderPath();
                        openStage(nextIdx);
                    } else {
                        // all done!
                        state.allCompleted = true;
                        pathView.style.display = 'block';
                        lessonView.classList.remove('visible');
                        renderPath();
                        // show celebration
                        alert('🎉 Congratulations! You completed all stages! You are a Hiragana master!');
                    }
                });
            }

            // ---- check if stage is fully complete ----
            checkStageComplete(index);
        }

        // ================================================================
        //  CHECK STAGE COMPLETE
        // ================================================================

        function checkStageComplete(index) {
            if (state.stagesDone[index]) return;
            const prog = state.stageProgress[index];
            const stage = STAGES[index];
            const allQuiz = stage.quiz.length > 0 ? prog.quizDone.length >= stage.quiz.length : true;
            const allWriting = stage.writing.length > 0 ? prog.writingDone.length >= stage.writing.length : true;
            if (allQuiz && allWriting) {
                // stage complete!
                state.stagesDone[index] = true;
                state.stageProgress[index].completed = true;
                renderPath();
                // re-render lesson to show completion state
                renderLesson(index);
                updateHearts();
            }
        }

        // ================================================================
        //  HEARTS & GAME OVER
        // ================================================================

        function loseHeart(index) {
            state.hearts = Math.max(0, state.hearts - 1);
            updateHearts();
            // animate heart
            headerHearts.classList.remove('heart-beat');
            void headerHearts.offsetWidth;
            headerHearts.classList.add('heart-beat');

            if (state.hearts <= 0) {
                // game over
                gameOverOverlay.classList.add('visible');
            }
        }

        function updateHearts() {
            heartCount.textContent = state.hearts;
            // color change
            if (state.hearts <= 2) {
                headerHearts.style.borderColor = 'rgba(255,107,107,0.5)';
            } else {
                headerHearts.style.borderColor = 'rgba(255,107,107,0.2)';
            }
        }

        function resetHearts() {
            state.hearts = state.maxHearts;
            updateHearts();
            headerHearts.classList.remove('heart-beat');
        }

        // ================================================================
        //  GAME OVER RESTART
        // ================================================================

        restartBtn.addEventListener('click', () => {
            gameOverOverlay.classList.remove('visible');
            // reset hearts
            resetHearts();
            // reset current stage progress
            const idx = state.currentStage;
            state.stageProgress[idx].quizDone = [];
            state.stageProgress[idx].writingDone = [];
            state.stageProgress[idx].cardsFlipped = false;
            state.stageProgress[idx].quizAnswered = false;
            state.stageProgress[idx].writingAnswered = false;
            state.stageProgress[idx].completed = false;
            state.stagesDone[idx] = false;
            state.quizIndex = 0;
            state.writingIndex = 0;
            state.quizLocked = false;
            state.writingLocked = false;
            state.stageCompleted = false;
            renderPath();
            renderLesson(idx);
            updateHearts();
        });

        // ================================================================
        //  BACK TO PATH
        // ================================================================

        backBtn.addEventListener('click', () => {
            lessonView.classList.remove('visible');
            pathView.style.display = 'block';
            renderPath();
            // if stage is completed, update
            checkStageComplete(state.currentStage);
        });

        // ================================================================
        //  INIT
        // ================================================================

        function init() {
            resetHearts();
            renderPath();
            // auto-open first stage if not done
            if (!state.stagesDone[0]) {
                openStage(0);
            } else {
                // find first incomplete
                const firstIncomplete = state.stagesDone.findIndex(d => !d);
                if (firstIncomplete !== -1) {
                    openStage(firstIncomplete);
                } else {
                    // all done
                    pathView.style.display = 'block';
                    lessonView.classList.remove('visible');
                    renderPath();
                }
            }
        }

        init();

        // ================================================================
        //  KEYBOARD SUPPORT: ENTER for writing
        // ================================================================

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const checkBtn = document.getElementById('checkWriting');
                if (checkBtn && !checkBtn.disabled) {
                    checkBtn.click();
                }
            }
        });

        // ================================================================
        //  PREVENT ZOOM ON DOUBLE TAP (mobile)
        // ================================================================

        document.addEventListener('touchend', (e) => {
            const now = Date.now();
            if (now - (document.lastTouch || 0) < 300) {
                e.preventDefault();
            }
            document.lastTouch = now;
        }, { passive: false });

        console.log('🇯🇵 Mehdi San — Learn Japanese with ❤️');
    </script>
</body>
</html>
